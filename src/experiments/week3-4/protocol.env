# Shell-compatible frozen defaults for the Weeks 3 & 4 PointNav baseline.
# Every assignment keeps an existing environment override when one is supplied.

PROFILE="${PROFILE:-gibson}"
EXPECTED_HABITAT_REVISION="${EXPECTED_HABITAT_REVISION:-cdbb4880519505adf45fba0f0c0c3a3fd18a2a55}"
PRIMARY_SEED="${PRIMARY_SEED:-100}"
REPEAT_SEEDS="${REPEAT_SEEDS:-200 300}"
TRAIN_SEED="${TRAIN_SEED:-$PRIMARY_SEED}"
EVAL_SEED="${EVAL_SEED:-2026}"

GIBSON_TOTAL_STEPS="${GIBSON_TOTAL_STEPS:-5000000}"
HABITAT_TEST_TOTAL_STEPS="${HABITAT_TEST_TOTAL_STEPS:-1000000}"
TOTAL_STEPS="${TOTAL_STEPS:-}"

GIBSON_NUM_ENVIRONMENTS="${GIBSON_NUM_ENVIRONMENTS:-5}"
HABITAT_TEST_NUM_ENVIRONMENTS="${HABITAT_TEST_NUM_ENVIRONMENTS:-1}"
NUM_ENVIRONMENTS="${NUM_ENVIRONMENTS:-}"
NUM_CHECKPOINTS="${NUM_CHECKPOINTS:-10}"

EVAL_SPLIT="${EVAL_SPLIT:-val}"
EVAL_EPISODES="${EVAL_EPISODES:-100}"
GIBSON_EVAL_NUM_ENVIRONMENTS="${GIBSON_EVAL_NUM_ENVIRONMENTS:-5}"
HABITAT_TEST_EVAL_NUM_ENVIRONMENTS="${HABITAT_TEST_EVAL_NUM_ENVIRONMENTS:-2}"
EVAL_NUM_ENVIRONMENTS="${EVAL_NUM_ENVIRONMENTS:-}"
SAVE_VIDEO="${SAVE_VIDEO:-0}"

MIN_GIBSON_SCENES="${MIN_GIBSON_SCENES:-88}"
SCENE_DATASET_CONFIG="${SCENE_DATASET_CONFIG:-data/scene_datasets/gibson/gibson.scene_dataset_config.json}"
EGL_VENDOR_JSON="${EGL_VENDOR_JSON:-/usr/share/glvnd/egl_vendor.d/10_nvidia.json}"

HABITAT_ROOT="${HABITAT_ROOT:-$HOME/habitat-lab}"
PYTHON_BIN="${PYTHON_BIN:-python}"
ALLOW_REVISION_MISMATCH="${ALLOW_REVISION_MISMATCH:-0}"
